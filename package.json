{
  "name": "eveng2s",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "tsc && vite build --config vite.web.config.ts",
    "dev:game": "vite --config vite.game.config.ts",
    "build:game": "tsc && vite build --config vite.game.config.ts",
    "sim:game": "evenhub-simulator http://localhost:5175",
    "pack:game": "evenhub pack game.app.json dist-game -o lost-signal.ehpk",
    "preview": "vite preview",
    "sim": "evenhub-simulator http://localhost:5173",
    "qr": "evenhub qr --url http://localhost:5173",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10",
    "@evenrealities/pretext": "^0.1.4"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@evenrealities/evenhub-simulator": "^0.7.3",
    "playwright": "^1.60.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
